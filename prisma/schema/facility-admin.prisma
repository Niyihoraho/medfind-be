// ─── FACILITY ADMIN ──────────────────────────────────────────────
// Feature table: which users manage which facilities.
// Critical: a facility_admin can ONLY modify facilities they are
// listed in this table for. Enforced at middleware level.

model FacilityAdmin {
  id         BigInt            @id @default(autoincrement())
  facilityId BigInt            @map("facility_id")
  userId     BigInt            @map("user_id")
  role       FacilityAdminRole @default(editor)
  assignedAt DateTime          @default(now()) @map("assigned_at")

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([facilityId, userId], name: "unique_facility_user")
  @@map("facility_admins")
}
