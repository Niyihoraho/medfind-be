// ─── SECTOR ──────────────────────────────────────────────────────
// Third-level administrative unit, belongs to a District.
// Facilities are assigned to sectors.

model Sector {
  id         BigInt  @id @default(autoincrement())
  name       String  @db.VarChar(191)
  nameRw     String? @map("name_rw") @db.VarChar(191)
  districtId BigInt  @map("district_id")

  district   District   @relation(fields: [districtId], references: [id], onDelete: Cascade)
  cells      Cell[]
  facilities Facility[]

  @@index([districtId], name: "fk_sector_district")
  @@map("sectors")
}
