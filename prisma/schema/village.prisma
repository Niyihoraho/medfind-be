// ─── VILLAGE ─────────────────────────────────────────────────────
// Fifth-level administrative unit (smallest), belongs to a Cell.

model Village {
  id         BigInt  @id @default(autoincrement())
  name       String  @db.VarChar(191)
  nameRw     String? @map("name_rw") @db.VarChar(191)
  cellId     BigInt  @map("cell_id")

  cell       Cell       @relation(fields: [cellId], references: [id], onDelete: Cascade)
  facilities Facility[]

  @@index([cellId], name: "fk_village_cell")
  @@map("villages")
}
