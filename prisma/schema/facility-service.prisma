// ─── FACILITY SERVICE ────────────────────────────────────────────
// Junction table: which services a facility offers.
// is_available allows toggling without removing the association.

model FacilityService {
  id          BigInt  @id @default(autoincrement())
  facilityId  BigInt  @map("facility_id")
  serviceId   BigInt  @map("service_id")
  isAvailable Boolean @default(true) @map("is_available")

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([facilityId, serviceId], name: "unique_facility_service")
  @@map("facility_services")
}
