// ─── PLACE CENTER ────────────────────────────────────────────────
// Coordinates for any administrative place (province, district, sector).
// Polymorphic — no hard FK, enforced at application layer.
// Used as GPS-off fallback: when user selects a sector, we use its
// center_lat/lng as the distance reference point.

model PlaceCenter {
  id        BigInt    @id @default(autoincrement())
  placeType PlaceType @map("place_type")
  placeId   BigInt    @map("place_id")
  centerLat Decimal   @map("center_lat") @db.Decimal(10, 8)
  centerLng Decimal   @map("center_lng") @db.Decimal(11, 8)

  @@unique([placeType, placeId], name: "unique_place")
  @@map("place_centers")
}
