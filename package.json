{
  "name": "medfind-backend",
  "version": "1.0.0",
  "description": "MEDFIND Healthcare API — Express + Prisma + MySQL",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "db:generate": "prisma generate --schema=prisma/schema",
    "db:migrate": "prisma migrate dev --schema=prisma/schema",
    "db:push": "prisma db push --schema=prisma/schema",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio --schema=prisma/schema"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "schema": "prisma/schema"
  }
}
